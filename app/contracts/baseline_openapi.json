{
  "openapi": "3.1.0",
  "info": {
    "title": "PyPulse Courier API",
    "description": "Contract-driven courier service system",
    "version": "0.1.0"
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Register",
        "description": "Registers a new user.\n\nDelegates logic to service layer.",
        "operationId": "register_auth_register_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/pickup/": {
      "post": {
        "tags": [
          "Pickup"
        ],
        "summary": "Create Pickup Route",
        "description": "Creates a new pickup request.",
        "operationId": "create_pickup_route_pickup__post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PickupCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tracking/": {
      "post": {
        "tags": [
          "Tracking"
        ],
        "summary": "Track Shipment",
        "operationId": "track_shipment_tracking__post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TrackingRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tracking/status": {
      "patch": {
        "tags": [
          "Tracking"
        ],
        "summary": "Update Shipment Status",
        "operationId": "update_shipment_status_tracking_status_patch",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TrackingStatusUpdate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health Check",
        "description": "Service health endpoint",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AddressType": {
        "properties": {
          "type": {
            "type": "string",
            "title": "Type",
            "description": "Home / Office / Warehouse",
            "examples": [
              "home",
              "office"
            ]
          },
          "city": {
            "type": "string",
            "maxLength": 50,
            "minLength": 2,
            "title": "City"
          },
          "zip_code": {
            "type": "string",
            "maxLength": 10,
            "minLength": 4,
            "title": "Zip Code"
          }
        },
        "type": "object",
        "required": [
          "type",
          "city",
          "zip_code"
        ],
        "title": "AddressType"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PickupCreate": {
        "properties": {
          "sender_name": {
            "type": "string",
            "maxLength": 50,
            "minLength": 2,
            "title": "Sender Name"
          },
          "sender_id": {
            "type": "integer",
            "title": "Sender Id"
          },
          "receiver_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Receiver Name"
          },
          "priority": {
            "type": "string",
            "title": "Priority",
            "description": "low | medium | high"
          },
          "package_weight": {
            "type": "number",
            "maximum": 100.0,
            "minimum": 0.1,
            "title": "Package Weight"
          },
          "address": {
            "$ref": "#/components/schemas/AddressType"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tags"
          }
        },
        "type": "object",
        "required": [
          "sender_name",
          "sender_id",
          "priority",
          "package_weight",
          "address"
        ],
        "title": "PickupCreate",
        "description": "Intentional complexity added for diff testing."
      },
      "TrackingRequest": {
        "properties": {
          "tracking_id": {
            "type": "string",
            "title": "Tracking Id"
          }
        },
        "type": "object",
        "required": [
          "tracking_id"
        ],
        "title": "TrackingRequest"
      },
      "TrackingStatusUpdate": {
        "properties": {
          "tracking_id": {
            "type": "string",
            "title": "Tracking Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "tracking_id",
          "status"
        ],
        "title": "TrackingStatusUpdate"
      },
      "UserCreate": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "email": {
            "type": "string",
            "title": "Email"
          }
        },
        "type": "object",
        "required": [
          "name",
          "email"
        ],
        "title": "UserCreate"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}